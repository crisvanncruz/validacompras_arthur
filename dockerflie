FROM nikolaik/python-nodejs:python3.10-nodejs18

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY backend/requirements.txt ./backend/

RUN pip install --no-cache-dir -r backend/requirements.txt

COPY . .

RUN npm run build

EXPOSE 3000

ENV NODE_ENV=production

CMD ["npx", "ts-node", "server.ts"]